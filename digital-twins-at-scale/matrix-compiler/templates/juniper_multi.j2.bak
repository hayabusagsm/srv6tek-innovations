# ==============================================================================
# JUNIPER cRPD MASTER BLUEPRINT - PART A (SYSTEM, CLEANED VRFS, & INTERFACES)
# Node: {{ node.node_id }} | AS: {{ node.asn }} | Technology: {{ node.tech }}
# ==============================================================================

version 24.2R1-S1.10;

{% if node.tech == 'srv6' %}
groups {
    GR-SRV6 {
        routing-options {
            source-packet-routing {
                srv6 {
                    locator "MAIN" { micro-sid { flavor psp; flavor usd; } }
                    locator "LATENCY_1" { micro-sid { flavor psp; flavor usd; } }
                    locator "LATENCY_2" { micro-sid { flavor psp; flavor usd; } }
                    locator "LATENCY_3" { micro-sid { flavor psp; flavor usd; } }
                }
            }
        }
    }
}
{% endif %}

system {
    host-name {{ node.node_id }};
    domain-name ://verizon.com;
    
    login {
        message "\n************************* NOTICE *************************\nSRv6TEK Innovations Digital Twin Operating System\n************************* NOTICE *************************\n";
        user gyan {
            uid 2004;
            class super-user;
            authentication {
                encrypted-password "$6$Pmpd4Oqf$iNFLKUBgsQW53WTzWv0dKtxdHNyVOY4kMu2MGD.BDvLhglBAP6uK2mQTOndfcSli5Yi2kWWcle8lkhxhKNsqn/";
            }
        }
        user admin {
            uid 2002;
            class super-user;
            authentication {
                encrypted-password "$6$z/xQ3aNP$WMKu3fO/CEUTubKgx1M2S3izpS/JHNbV72xKk90lvzYo1Qm38Uopc.tikNj5p3.LKyhtG/TdADbqhg1yF4qej/";
            }
        }
    }
    services {
        ssh {
            root-login allow;
            protocol-version v2;
        }
        netconf {
            ssh;
        }
    }
}

routing-instances {
    {% if node.role == "PE" %}
    vrf_red {
        instance-type vrf;
        interface lo0.1;
        route-distinguisher {{ node.asn }}:1;
        vrf-target target:1:1;
        routing-options {
            protect core;
            {% if node.tech == 'srv6' %}
            rib vrf_red.inet6.0 { protect core; }
            {% endif %}
        }
        protocols {
            bgp {
                {% if node.tech == 'srv6' %}
                source-packet-routing { srv6 { locator LATENCY_1 { micro-dt4-sid; micro-dt6-sid; } } }
                {% endif %}
            }
        }
    }
    vrf_green {
        instance-type vrf;
        interface lo0.2;
        route-distinguisher {{ node.asn }}:2;
        vrf-target target:2:2;
        routing-options { protect core; }
        protocols {
            bgp {
                {% if node.tech == 'srv6' %}
                source-packet-routing { srv6 { locator LATENCY_2 { micro-dt4-sid; micro-dt6-sid; } } }
                {% endif %}
            }
        }
    }
    vrf_blue {
        instance-type vrf;
        interface lo0.3;
        route-distinguisher {{ node.asn }}:3;
        vrf-target target:3:3;
        routing-options { protect core; }
        protocols {
            bgp {
                {% if node.tech == 'srv6' %}
                source-packet-routing { srv6 { locator LATENCY_3 { micro-dt4-sid; micro-dt6-sid; } } }
                {% endif %}
            }
        }
    }
    {% if node.tech == "srv6" %}
    vrf_main {
        instance-type vrf;
        interface lo0.4;
        route-distinguisher {{ node.asn }}:4;
        vrf-target target:4:4;
        routing-options { protect core; }
        protocols {
            bgp {
                source-packet-routing { srv6 { locator MAIN { micro-dt4-sid; micro-dt6-sid; } } }
            }
        }
    }
    {% endif %}
    {% endif %}
}
# --- JUNIPER cRPD MASTER BLUEPRINT - PART B (SR-PM PROBES, IS-IS STATIC DELAYS & BGP) --- #

routing-options {
    router-id 10.0.0.{{ node.node_num }};
    {% if node.tech == 'srv6' %}
    source-packet-routing {
        srv6 {
            locator MAIN { prefix {{ node.locators.main }}; }
            locator LATENCY_1 { prefix {{ node.locators.red }}; }
            locator LATENCY_2 { prefix {{ node.locators.green }}; }
            locator LATENCY_3 { prefix {{ node.locators.blue }}; }
        }
    }
    {% endif %}
}

policy-options {
    policy-statement SET_COLOR_ALL_VPNV4 {
        term red_v4 {
            from vrf vrf_red;
            then { community add COLOR_V4_10; accept; }
        }
        term green_v4 {
            from vrf vrf_green;
            then { community add COLOR_V4_20; accept; }
        }
        term blue_v4 {
            from vrf vrf_blue;
            then { community add COLOR_V4_30; accept; }
        }
        {% if node.tech == "srv6" %}
        term main_v4 {
            from vrf vrf_main;
            then { community add COLOR_V4_40; accept; }
        }
        {% endif %}
        term next_policy { then accept; }
    }

    policy-statement SET_COLOR_ALL_VPNV6 {
        term red_v6 {
            from vrf vrf_red;
            then { community add COLOR_V6_100; accept; }
        }
        term green_v6 {
            from vrf vrf_green;
            then { community add COLOR_V6_200; accept; }
        }
        term blue_v6 {
            from vrf vrf_blue;
            then { community add COLOR_V6_300; accept; }
        }
        {% if node.tech == "srv6" %}
        term main_v6 {
            from vrf vrf_main;
            then { community add COLOR_V6_400; accept; }
        }
        {% endif %}
        term next_policy { then accept; }
    }

    community COLOR_V4_10 members color:0:10;
    community COLOR_V4_20 members color:0:20;
    community COLOR_V4_30 members color:0:30;
    community COLOR_V4_40 members color:0:40;
    community COLOR_V6_100 members color:0:100;
    community COLOR_V6_200 members color:0:200;
    community COLOR_V6_300 members color:0:300;
    community COLOR_V6_400 members color:0:400;
}

interfaces {
    lo0 {
        unit 0 {
            family inet6 { address {{ node.loopback0 }}/128; }
            family iso { address {{ node.nsap }}; }
        }
        {% if node.role == "PE" %}
        unit 1 { family inet; family inet6; }
        unit 2 { family inet; family inet6; }
        unit 3 { family inet; family inet6; }
        unit 4 { family inet; family inet6; }
        {% endif %}
    }
    {% for intf in node.interfaces %}
    {{ intf.name }} {
        description "{{ intf.desc }}";
        unit 0 {
            {% if node.topo == "internet-sim" %}
            family inet { address {{ intf.v4_ip }}; }
            family inet6 { address {{ intf.v6_ip }}; }
            {% else %}
            family inet6;
            {% endif %}
            family mpls;
            family iso;
        }
    }
    {% endfor %}
}

protocols {
    isis {
        level 2 { wide-metrics-only; }
        affinity-map red bit-position 1;
        affinity-map green bit-position 2;
        affinity-map blue bit-position 3;

        {% for intf in node.interfaces %}
        interface {{ intf.name }}.0 {
            circuit-type level-2-only;
            point-to-point;
            hello-padding disable;
            affinity flex-algo red green blue;
            {# Injecting static ocean-bed metrics directly into Junos IS-IS TLVs #}
            {% if node.topo in ['mega-internet', 'tier-2-emea', 'tier-2-apac', 'tier-1'] %}
             static-delay 45000;
            {% endif %}
        }
        {% endfor %}
        interface lo0.0;
    }
    
    {# --- Activation Plane for Performance Measurement (SR-PM) in Junos --- #}
    {% if node.tech == 'srv6' or node.tech == 'sr-mpls' %}
    performance-measurement {
        delay-measurement {
            {% for intf in node.interfaces %}
            interface {{ intf.name }} {
                static-delay 45000;
                advertise-delay 1000;
            }
            {% endfor %}
        }
    }
    {% endif %}

    bgp {
        {% if node.role == "PE" %}
        group RR-CLUSTER-PEERS {
            type internal;
            local-address {{ node.loopback0 }};
            autonomous-system {{ node.asn }};
            multipath multiple-as;
            
            family inet-vpn { unicast; export SET_COLOR_ALL_VPNV4; }
            family inet6-vpn { unicast; export SET_COLOR_ALL_VPNV6; }
            family traffic-engineering { bgp-ls; }
            
            {% for peer in node.rr_peers %}
            neighbor {{ peer }};
            {% endfor %}
        }
        
        group INTER-AS-PE-PEERS {
            type external;
            local-address {{ node.loopback0 }};
            multipath multiple-as;
            
            family inet-vpn { unicast; export SET_COLOR_ALL_VPNV4; }
            family inet6-vpn { unicast; export SET_COLOR_ALL_VPNV6; }
        }
        {% endif %}
    }
    
    {% if node.tech == 'mpls-ldp' or node.tech == 'rsvp-te' %}
    mpls {
        oam;
        {% for intf in node.interfaces %}
        interface {{ intf.name }}.0;
        {% endfor %}
        {# --- Enable RSVP-TE Forwarding Adjacency Shortcuts --- #}
        {% if node.tech == 'rsvp-te' %}
        traffic-engineering-shortcuts;
        forwarding-adjacency;
        {% endif %}
    }
    {% endif %}
}
